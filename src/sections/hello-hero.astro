---
import AccentActive from "@/components/accent/accent-active.astro";
import { Button } from "@/components/ui/button";
import { IconBrandLinkedin, IconBrandGithub } from "@tabler/icons-react";
import data from "@/data/general.json";
import { Shine } from "@/components/animate-ui/primitives/effects/shine";
import { dictionary } from "@/dictionaries";

interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const dict = dictionary(lang);
---

<section class="min-h-screen flex items-center justify-center">
  <div class="flex flex-col items-center justify-center gap-8 px-4">
    <!-- Título pequeño -->
    <p
      class="text-xl lg:text-2xl md:text-base text-stone-700 text-center max-w-2xl"
    >
      {dict.home.subtitle}
    </p>

    <!-- Título principal -->
    <h1
      class="text-6xl md:text-8xl lg:text-8xl text-stone-800 text-center font-semibold"
    >
      {
        dict.home.title.map((e) => {
          if (e === "{accent}") return <AccentActive />;
          if (e === "{br}") return <br />;
          return e;
        })
      }
    </h1>

    <!-- Botones de contacto -->
    <div class="flex flex-col sm:flex-row gap-4 items-center">
      <Shine
        client:load
        loop
        loopDelay={5000}
        className="rounded-full"
        opacity={0.05}
      >
        <a
          href={data.personal.linkedin}
          target="_blank"
          rel="noopener noreferrer"
        >
          <Button
            client:load
            variant={"outline"}
            className="cursor-pointer h-13 text-md rounded-full"
          >
            <IconBrandLinkedin className="size-7 opacity-80" />
            {dict.home.buttons.contact}
          </Button>
        </a>
      </Shine>
      <a href={data.personal.github} target="_blank" rel="noopener noreferrer">
        <Button
          client:load
          variant={"outline"}
          className="cursor-pointer h-13 text-md rounded-full"
        >
          <IconBrandGithub className="size-7 opacity-80" />
          {dict.home.buttons.github}
        </Button>
      </a>
    </div>

    <!-- Barra animada -->
    <div
      class="w-32 h-1 bg-stone-900 animate-bounce-slow rounded-full opacity-60"
    >
    </div>
  </div>
</section>
