---
const { class: className } = Astro.props;
---

<section class:list={["hero", className]}>
  <svg id="matrix-bg" class="matrix-background"></svg>
  <div class="hero-content">
    <slot />
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .matrix-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .matrix-background text {
    fill: #c7c7c7;
    font-family: monospace;
    animation: fadeColor 3s ease-in-out infinite;
  }

  @keyframes fadeColor {
    0%,
    100% {
      fill: #ad3636;
    }
    50% {
      fill: #b0b0b0;
    }
  }
</style>

<script>
  const svg = document.getElementById("matrix-bg") as SVGSVGElement;

  if (svg) {
    // Configuración de la grilla
    const fontSize = 17;
    const columns = Math.floor(window.innerWidth / fontSize);
    const rows = Math.floor(window.innerHeight / fontSize);

    // Configurar tamaño del SVG
    svg.setAttribute("width", window.innerWidth.toString());
    svg.setAttribute("height", window.innerHeight.toString());
    svg.setAttribute(
      "viewBox",
      `0 0 ${window.innerWidth} ${window.innerHeight}`,
    );

    // Crear grilla de caracteres
    for (let i = 0; i < rows; i++) {
      for (let j = 0; j < columns; j++) {
        const char = Math.random() > 0.5 ? "1" : "0";
        const x = j * fontSize + fontSize / 2;
        const y = i * fontSize + fontSize / 2;

        const text = document.createElementNS(
          "http://www.w3.org/2000/svg",
          "text",
        );
        text.setAttribute("x", x.toString());
        text.setAttribute("y", y.toString());
        text.setAttribute("text-anchor", "middle");
        text.setAttribute("dominant-baseline", "middle");
        text.setAttribute("font-size", fontSize.toString());
        text.textContent = char;

        // Delay aleatorio para cada elemento
        const randomDelay = Math.random() * 3;
        text.style.animationDelay = `${randomDelay}s`;

        svg.appendChild(text);
      }
    }

    // Redimensionar SVG
    window.addEventListener("resize", () => {
      svg.setAttribute("width", window.innerWidth.toString());
      svg.setAttribute("height", window.innerHeight.toString());
      svg.setAttribute(
        "viewBox",
        `0 0 ${window.innerWidth} ${window.innerHeight}`,
      );
    });
  }
</script>
