<span class="inline-block relative w-14 max-md:w-11 h-14 max-md:h-11">
  <!-- Símbolo cuadrado -->
  <span
    id="symbol"
    class="block bg-accent aspect-square w-14 max-md:w-11 h-14 max-md:h-11 rotate-12 transition-all duration-1000 ease-in-out animate-wiggle"
  ></span>

  <!-- Branches SVG (código) -->
  <svg
    id="branches"
    class="absolute inset-0 w-14 max-md:w-11 h-14 max-md:h-11 opacity-0 p-2"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    xmlns="http://www.w3.org/2000/svg"
  >
    <line x1="6" y1="3" x2="6" y2="15"></line>
    <circle cx="18" cy="6" r="3"></circle>
    <circle cx="6" cy="18" r="3"></circle>
    <path d="M18 9a9 9 0 0 1-9 9"></path>
  </svg>

  <!-- Corazón SVG -->
  <svg
    id="heart"
    class="absolute inset-0 w-14 max-md:w-11 h-14 max-md:h-11 opacity-0"
    viewBox="0 0 24 24"
    fill="currentColor"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
    ></path>
  </svg>
</span>

<script>
  import { Scene, Stage } from "@/lib/stage";

  const symbol = document.getElementById("symbol");
  const branches = document.getElementById("branches");
  const heart = document.getElementById("heart");

  // Escena del símbolo: mostrar símbolo por 5 segundos (reutilizable)
  const symbolScene = new Scene({
    duration: 5000,
    start() {
      // Mostrar símbolo
      symbol?.classList.remove("opacity-0", "scale-0");
      symbol?.classList.add("opacity-100", "scale-100");
    },
    stop() {
      // Ocultar símbolo
      symbol?.classList.add("opacity-0", "scale-0");
      symbol?.classList.remove("opacity-100", "scale-100");
    },
  });

  // Escena de branches: mostrar branches por 1 segundo
  const branchScene = new Scene({
    duration: 1000,
    start() {
      // Mostrar branches
      branches?.classList.remove("opacity-0");
      branches?.classList.add("opacity-100", "animate-spin-slow");
    },
    stop() {
      // Ocultar branches
      branches?.classList.remove("animate-spin-slow", "opacity-100");
      branches?.classList.add("opacity-0");
    },
  });

  // Escena de corazón: mostrar corazón por 1 segundo
  const heartScene = new Scene({
    duration: 1000,
    start() {
      // Mostrar corazón
      heart?.classList.remove("opacity-0");
      heart?.classList.add("opacity-100", "animate-bounce-heart");
    },
    stop() {
      // Ocultar corazón
      heart?.classList.remove("animate-bounce-heart", "opacity-100");
      heart?.classList.add("opacity-0");
    },
  });

  // Crear el stage con las escenas en secuencia
  // Reutilizamos symbolScene entre las animaciones
  new Stage([symbolScene, branchScene, symbolScene, heartScene]);
</script>

<style>
  @keyframes wiggle {
    0%,
    100% {
      transform: rotate(12deg);
    }
    50% {
      transform: rotate(24deg);
    }
  }

  .animate-wiggle {
    animation: wiggle 2s ease-in-out infinite;
  }

  @keyframes spin-slow {
    0% {
      transform: rotate(0deg) scale(1);
    }
    50% {
      transform: rotate(180deg) scale(1.1);
    }
    100% {
      transform: rotate(360deg) scale(1);
    }
  }

  .animate-spin-slow {
    animation: spin-slow 1s ease-in-out;
  }

  @keyframes bounce-heart {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    25% {
      transform: translateY(-20px) scale(1.1);
    }
    50% {
      transform: translateY(0) scale(1);
    }
    75% {
      transform: translateY(-10px) scale(1.05);
    }
  }

  .animate-bounce-heart {
    animation: bounce-heart 1s ease-in-out;
  }

  #symbol {
    transition:
      opacity 0.3s ease-in-out,
      transform 0.3s ease-in-out;
  }

  #branches,
  #heart {
    color: var(--accent);
    transition: opacity 0.3s ease-in-out;
  }
</style>
