---
import { Temporal } from "temporal-polyfill";

export const prerender = false;

interface Props {
  articleId: string;
}

const { articleId } = Astro.props;

const keyCache = `blog-post-${articleId}-visited`;

const visited = (await Astro.cookies.get(keyCache)?.boolean()) ?? false;

if (!visited) {
  await Astro.cookies.set(keyCache, "true", {
    path: import.meta.url,
    maxAge: Temporal.Duration.from({ weeks: 1 }).total("seconds"),
  });
}

const getVisits = async (): Promise<number> => {
  const visits: number = Number(
    (await Astro.locals.runtime.env.BLOG_POSTS_VISITS.get(articleId)) ?? 0,
  );

  if (visited) return visits;

  await Astro.locals.runtime.env.BLOG_POSTS_VISITS.put(
    articleId,
    String(visits + 1),
  );

  return visits + 1;
};

const visits = await getVisits();
---

{visits}
