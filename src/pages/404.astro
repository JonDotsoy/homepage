---
import DefaultLayout from "@/components/layouts/DefaultLayout.astro";
import Footer from "@/sections/footer.astro";
import "@/styles/global.css";
---

<DefaultLayout lang="en" title="Page not found">
    <div class="container mx-auto px-4 py-4">
        <div class="grid grid-cols-1 min-h-screen content-around">
            <div class="text-center">
                <div class="mb-8">
                    <h1 class="text-9xl font-bold text-primary">404</h1>
                </div>

                <h2 class="mb-4 text-3xl font-semibold">Page not found</h2>

                <p class="mb-8 text-lg opacity-70">
                    Sorry, the page you're looking for doesn't exist or has been
                    moved.
                </p>

                <div class="mt-12 text-sm opacity-50">
                    <p>
                        <span>Think this is a mistake? </span><a
                            href="https://github.com/JonDotsoy/homepage/issues/new"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="underline hover:opacity-80"
                            >Create an issue on GitHub</a
                        >
                    </p>
                </div>
            </div>
        </div>
    </div>
    <Footer lang="en" />
</DefaultLayout>
