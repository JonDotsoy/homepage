---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import DefaultLayout from "../components/layouts/DefaultLayout.astro";
import { Temporal } from "temporal-polyfill";

export const prerender = true;

const allBlogPosts = await getCollection("blog");
const sortedPosts = allBlogPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const postsWithOptimizedImages = await Promise.all(
  sortedPosts.map(async (post) => {
    const optimizedCover = post.data.cover
      ? await getImage({
          src: post.data.cover,
          width: 400,
          height: 200,
          format: "webp",
        })
      : null;

    return {
      id: post.id,
      title: post.data.title,
      author: post.data.author.github ?? null,
      description: post.data.description,
      date: post.data.date,
      plainDate: Temporal.PlainDate.from(post.data.date),
      optimizedCover,
    };
  }),
);

// Group by month and year (newest first)
const postsByMonthYear = postsWithOptimizedImages.reduce(
  (acc, post) => {
    const postPlainDate = post.plainDate;
    const monthPlainDate = postPlainDate.with({ day: 1 });
    const monthPlainDateString = monthPlainDate.toJSON();
    if (!acc.has(monthPlainDateString)) acc.set(
      monthPlainDateString,
      {
        monthPlainDateString,
        monthPlainDate,
        posts: [],
      }
    );
    acc.get(monthPlainDateString)!.posts.push(post);
    return acc;
  },
  new Map<string, { monthPlainDateString: string; monthPlainDate: Temporal.PlainDate; posts: typeof postsWithOptimizedImages }>(),
);
const groupedPosts = Array.from(postsByMonthYear.values());

const blogUrl = new URL("/blog", Astro.site || Astro.url.origin).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Blog - Jonathan Delgado",
  description: "Artículos sobre desarrollo web, tecnología y más",
  url: blogUrl,
  author: {
    "@type": "Person",
    name: "Jonathan Delgado",
    email: "hi@jon.soy",
    url: "https://jon.soy",
  },
  blogPost: await Promise.all(
    sortedPosts.map(async (post) => {
      const articleUrl = new URL(
        `/blog/${post.id}`,
        Astro.site || Astro.url.origin,
      ).href;
      let imageUrl = "";
      if (post.data.cover) {
        const optimizedCover = await getImage({
          src: post.data.cover,
          width: 1200,
          height: 630,
          format: "webp",
        });
        imageUrl = new URL(optimizedCover.src, Astro.site || Astro.url.origin)
          .href;
      }
      return {
        "@type": "BlogPosting",
        headline: post.data.title,
        description: post.data.description,
        url: articleUrl,
        image: imageUrl || undefined,
        datePublished: new Date(post.data.date).toISOString(),
        author: {
          "@type": "Person",
          name: post.data.author.name,
        },
      };
    }),
  ),
};
---

<DefaultLayout
  title="Blog - Jonathan Delgado"
  description="Artículos sobre desarrollo web, tecnología y más"
  lang="es"
>
  <Fragment slot="head">
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={blogUrl} />
    <meta property="og:title" content="Blog - Jonathan Delgado" />
    <meta
      property="og:description"
      content="Artículos sobre desarrollo web, tecnología y más"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:url" content={blogUrl} />
    <meta name="twitter:title" content="Blog - Jonathan Delgado" />
    <meta
      name="twitter:description"
      content="Artículos sobre desarrollo web, tecnología y más"
    />

    <!-- Canonical URL -->
    <link rel="canonical" href={blogUrl} />

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
  </Fragment>

  <div class="container mx-auto px-4 py-16">
    {
      groupedPosts.map(({ monthPlainDateString, monthPlainDate, posts }) => (
        <section class="mb-12">
          <h2 class="text-2xl font-bold mb-6 opacity-60 capitalize">{monthPlainDate.toLocaleString('es-CL', { month: 'long', year: 'numeric' })}</h2>

          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <article
                class="w-full bg-white/30 hover:bg-white/60 rounded-[12px] shadow-[0_4px_20px_rgba(0,0,0,0.09)] overflow-hidden flex flex-col"
                transition:name={`article-box-${post.id}`}
              >
            <a href={`/blog/${post.id}`} class="block">
              {/* <!-- Header: autor + fecha --> */}
              <div class="flex items-center justify-between px-5 py-4">
                <div class="flex items-center gap-2">
                  {/* <!-- Avatar --> */}
                  {/* <div class="w-8 h-8 rounded-full bg-black flex items-center justify-center shrink-0">
                    <span class="font-sans-ui text-white text-[13px] font-medium">J</span>
                  </div> */}
                  <span class="font-sans-ui text-black text-[13px] font-medium">
                    {post.author}
                  </span>
                </div>
                {/* <!-- Fecha --> */}
                <span
                  class="font-sans-ui text-[#888888] text-[12px]"
                  title={post.plainDate.toLocaleString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' })}
                >
                  {post.plainDate.toLocaleString('es-CL', { day: '2-digit', month: 'short', year: 'numeric' })}
                </span>
              </div>

              {/* <!-- Divider --> */}
              <div class="h-px bg-[#F0F0F0]" />

              {/* <!-- Body: título + descripción --> */}
              <div class="px-5 py-5 flex flex-col gap-[10px]">
                <h2 class="font-serif-display italic text-black text-[22px] leading-snug">
                  {post.title}
                </h2>
                <p class="font-sans-ui text-[#666666] text-[14px] leading-relaxed line-clamp-4">
                  {post.description}
                </p>
              </div>

              {/* <!-- Divider --> */}
              <div class="h-px bg-[#F0F0F0]" />

              {/* <!-- Cover (opcional) --> */}
              {post.optimizedCover && (
                <div class="w-full h-[180px] bg-[#DDDDDD] overflow-hidden">
                  <img
                    src={post.optimizedCover.src}
                    alt="Cover"
                    class="w-full h-full object-cover"
                  />
                </div>
              )}

              {/* <!-- Footer: tags + botón compartir --> */}
              {/* <div class="flex items-center justify-between px-5 py-4">
                <div class="flex items-center gap-[6px]">
                  <span class="font-sans-ui text-[#888888] text-[11px] bg-[#F5F5F5] px-[10px] py-[5px] rounded">Design</span>
                  <span class="font-sans-ui text-[#888888] text-[11px] bg-[#F5F5F5] px-[10px] py-[5px] rounded">Systems</span>
                </div>
                <button class="flex items-center gap-[6px] bg-black text-white font-sans-ui text-[13px] font-medium px-[14px] py-2 rounded-[6px] hover:opacity-80 transition-opacity cursor-pointer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                  </svg>
                  Share
                </button>
              </div> */}
            </a>
              </article>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</DefaultLayout>
