---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import DefaultLayout from "../components/layouts/DefaultLayout.astro";

const allBlogPosts = await getCollection("blog");
const sortedPosts = allBlogPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const postsWithOptimizedImages = await Promise.all(
  sortedPosts.map(async (post) => {
    if (post.data.cover) {
      const optimizedCover = await getImage({
        src: post.data.cover,
        width: 400,
        height: 200,
        format: "webp",
      });
      return { ...post, optimizedCover };
    }
    return post;
  }),
);

const blogUrl = new URL("/blog", Astro.site || Astro.url.origin).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Blog - Jonathan Delgado",
  description: "Artículos sobre desarrollo web, tecnología y más",
  url: blogUrl,
  author: {
    "@type": "Person",
    name: "Jonathan Delgado",
    email: "hi@jon.soy",
    url: "https://jon.soy",
  },
  blogPost: await Promise.all(
    sortedPosts.map(async (post) => {
      const articleUrl = new URL(
        `/blog/${post.id}`,
        Astro.site || Astro.url.origin,
      ).href;
      let imageUrl = "";
      if (post.data.cover) {
        const optimizedCover = await getImage({
          src: post.data.cover,
          width: 1200,
          height: 630,
          format: "webp",
        });
        imageUrl = new URL(optimizedCover.src, Astro.site || Astro.url.origin)
          .href;
      }
      return {
        "@type": "BlogPosting",
        headline: post.data.title,
        description: post.data.description,
        url: articleUrl,
        image: imageUrl || undefined,
        datePublished: new Date(post.data.date).toISOString(),
        author: {
          "@type": "Person",
          name: post.data.author.name,
        },
      };
    }),
  ),
};
---

<DefaultLayout
  title="Blog - Jonathan Delgado"
  description="Artículos sobre desarrollo web, tecnología y más"
  lang="es"
>
  <Fragment slot="head">
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={blogUrl} />
    <meta property="og:title" content="Blog - Jonathan Delgado" />
    <meta
      property="og:description"
      content="Artículos sobre desarrollo web, tecnología y más"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:url" content={blogUrl} />
    <meta name="twitter:title" content="Blog - Jonathan Delgado" />
    <meta
      name="twitter:description"
      content="Artículos sobre desarrollo web, tecnología y más"
    />

    <!-- Canonical URL -->
    <link rel="canonical" href={blogUrl} />

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
  </Fragment>

  <div class="container mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-8">Blog</h1>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        postsWithOptimizedImages.map((post) => (
          <article class="border border-border rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
            <a href={`/blog/${post.id}`} class="block">
              {"optimizedCover" in post && post.optimizedCover && (
                <img
                  src={post.optimizedCover.src}
                  alt={post.data.title}
                  width={post.optimizedCover.attributes.width}
                  height={post.optimizedCover.attributes.height}
                  class="w-full h-48 object-cover"
                />
              )}
              <div class="p-6">
                <h2
                  class="text-2xl font-semibold mb-2 hover:text-accent-foreground"
                  transition:name={`article-title-${post.id}`}
                >
                  {post.data.title}
                </h2>
                <p class="text-muted-foreground text-sm mb-3">
                  {new Date(post.data.date).toLocaleDateString("es-ES", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </p>
                <p class="text-foreground mb-4">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag: string) => (
                      <span class="text-xs bg-accent text-accent-foreground px-2 py-1 rounded">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</DefaultLayout>
